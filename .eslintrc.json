{
  "env": { 
    "browser": true, 
    "es2021": true 
  },
  "parserOptions": { 
    "ecmaVersion": 2021, 
    "sourceType": "script" 
  },
  "plugins": ["html"],
  "extends": [
    "eslint:recommended"
  ],
  "rules": {
    "no-unused-vars": "warn",
    "no-unreachable": "error",
    "no-extra-semi": "error",
    "no-unexpected-multiline": "error",
    "no-undef": "error"
  }
}
